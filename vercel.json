{
  "version": 2,
  "builds": [
    { "src": "api/dashboard-data.js", "use": "@vercel/node" },
    { "src": "index.html",            "use": "@vercel/static" },
    { "src": "style.css",             "use": "@vercel/static" },
    { "src": "app.js",                "use": "@vercel/static" },
    { "src": "config.js",             "use": "@vercel/static" },
    { "src": "favicon.png",           "use": "@vercel/static" },
    { "src": "legacylogo.webp",       "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/dashboard-data", "dest": "/api/dashboard-data.js" },
    { "src": "/",                   "dest": "/index.html" }
  ]
}
